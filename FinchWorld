import greenfoot.*;
import java.util.HashMap;
import java.util.List;

public class FinchWorld extends World {
    public static final int SCALE = 2; 
    private HashMap<String, Node> nodes = new HashMap<>();

    public FinchWorld() {    
        // Create a world 800x600 pixels
        super(800, 600, 1); 
        
        // 1. Initialize the map data
        setupNodes();
        
        // 2. Add the robot to the starting point (Police Station)
        addObject(new FinchActor(nodes), 100, 300);
        
        System.out.println("World initialized. Press SPACE to start!");
    }

private void setupNodes() {
    // Starting point
    nodes.put("Police", new Node("Police", 100, 300));
    
    // Junction A is 30cm to the right of Police
    nodes.put("A", new Node("A", 100 + (30 * SCALE), 300));
    
    // Hospital is UP and to the right from A (84cm away)
    // We subtract from Y to go "UP" on the screen
    nodes.put("Hospital", new Node("Hospital", 160 + (60 * SCALE), 150)); 
    
    // School is DOWN from the Hospital (110cm away)
    nodes.put("School", new Node("School", 160 + (60 * SCALE), 150 + (110 * SCALE)));
    
    // Central B is way down at the bottom (192cm from A)
    nodes.put("Central B", new Node("Central B", 100 + (30 * SCALE), 300 + (192 * SCALE)));

    // This loop draws the labels so you can check if they look like your drawing
    for (Node n : nodes.values()) {
        showText(n.name, n.x, n.y);
    }
}

    public void act() {
        if (Greenfoot.isKeyDown("space")) {
            startMission();
        }
    }

    public void startMission() {
        // This connects to your partner's Dijkstra code in FinchTest.java
        FinchTest.setupMap(); 
        List<String> path = FinchTest.findShortestPath("Police", "School");
        
        FinchActor robot = (FinchActor) getObjects(FinchActor.class).get(0);
        if (robot != null) {
            robot.movePath(path);
        }
    }
}
